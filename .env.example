# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=dev-secret-key-change-in-production

# Database
DATABASE_URL=sqlite:///flowspec.db

# JWT
JWT_SECRET_KEY=jwt-secret-key-change-in-production

# ExaBGP Configuration
EXABGP_HOST=localhost
EXABGP_PORT=6001
EXABGP_TIMEOUT=5

# FastNetMon Configuration
FASTNETMON_API_URL=http://localhost:8080
FASTNETMON_ENABLED=false

# Rule Defaults
DEFAULT_RULE_TTL_MINUTES=60
MAX_RULE_TTL_MINUTES=1440

# API Rate Limiting
RATELIMIT_ENABLED=true
RATELIMIT_RULES_PER_HOUR=100

# Logging
LOG_LEVEL=INFO

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
